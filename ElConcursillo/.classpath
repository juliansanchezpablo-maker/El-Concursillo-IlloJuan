<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry excluding="resource/" kind="src" path="src"/>
	<classpathentry kind="src" path="src/resource"/>
	<classpathentry kind="lib" path="lib/bson-5.0.1.jar"/>
	<classpathentry kind="lib" path="lib/mongodb-driver-core-5.0.1.jar"/>
	<classpathentry kind="lib" path="lib/mongodb-driver-sync-5.0.1.jar"/>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER">
		<attributes>
			<attribute name="module" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="output" path="bin"/>
</classpath>
